# NocoBase Docker Environment Variables
# Copy this file to .env and modify as needed

# Database configuration
DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nocobase
DB_USER=nocobase
DB_PASSWORD=nocobase_password

# PostgreSQL official image variables
POSTGRES_USER=nocobase
POSTGRES_PASSWORD=nocobase_password
POSTGRES_DB=nocobase

# NocoBase App configuration
APP_PORT=13000
APP_KEY=replace_with_a_random_string_at_least_32_chars
NODE_ENV=production

# Adminer (Database GUI) configuration
ADMINER_PORT=8080
